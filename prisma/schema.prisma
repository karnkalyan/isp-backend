  apiPort                  Int?
  apiTlsPort               Int?
  restBaseUrl              String?  @db.VarChar(500)
  restPort                 Int?
  sshPort                  Int?
  netconfPort              Int?
  restconfBaseUrl          String?  @db.VarChar(500)
  gnmiEndpoint             String?  @db.VarChar(500)
  snmpPort                 Int?
  snmpVersion              String?  @db.VarChar(16)
  tlsEnabled               Boolean  @default(false)
  verifyTls                Boolean  @default(true)
  trustedFingerprint       String?  @db.VarChar(255)
  legacySshEnabled         Boolean  @default(false)
  sshAlgorithmProfile      String   @default("AUTO") @db.VarChar(64)
  readyTimeoutMs           Int      @default(20000)
  commandTimeoutMs         Int      @default(20000)
  keepaliveIntervalMs      Int      @default(15000)
  keepaliveCountMax        Int      @default(3)
  reconnectEnabled         Boolean  @default(true)
  maxReconnectAttempts     Int      @default(3)
  liveMonitoringEnabled    Boolean  @default(true)
  pollingProfile           Json?
  lastSuccessfulProtocol   String?  @db.VarChar(32)
  lastSuccessfulAt         DateTime?
