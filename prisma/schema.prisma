  @@map("yeastar_system_status")
}

// ==================== ESEWA PAYMENT MODELS ====================
model ESewaTokenPayment {
  id                   String    @id @default(cuid())
  ispId                Int
  customerId           Int
  customerUniqueId     String    @db.VarChar(100)
  requestId            String    @unique @db.VarChar(191)
  amount               Float
  status               String    @db.VarChar(50)
  eSewaTransactionCode String?   @db.VarChar(191)
  packageDetails       Json
  orderId              String?   @db.VarChar(191)
  referenceCode        String?   @db.VarChar(191)
  createdAt            DateTime  @default(now())
  paidAt               DateTime?
  branchId             Int?
  branch               Branch?   @relation(fields: [branchId], references: [id], map: "esewa_payment_branch_fkey")
  customer             Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade, map: "esewa_payment_customer_fkey")
  isp                  ISP       @relation(fields: [ispId], references: [id], onDelete: Cascade, map: "esewa_payment_isp_fkey")

  @@index([requestId])
  @@index([customerUniqueId])
  @@index([eSewaTransactionCode])
  @@index([status])
  @@index([customerId])
  @@index([ispId])
  @@index([branchId])
}

model ESewaConfiguration {
  ispId        Int      @id @unique
  username     String   @db.VarChar(191)
  passwordHash String   @db.VarChar(191)
  clientSecret String   @db.VarChar(191)
  authMethod   String   @default("BEARER") @db.VarChar(50)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  isp          ISP                 @relation(fields: [ispId], references: [id], onDelete: Cascade, map: "esewa_config_isp_fkey")
  accessTokens ESewaAccessToken[]
  refreshTokens ESewaRefreshToken[]
}

model ESewaAccessToken {
  id            String   @id @default(cuid())
  token         String   @db.Text
  esewaConfigId Int
  expiresAt     DateTime
  isRevoked     Boolean  @default(false)
  createdAt     DateTime @default(now())
  esewaConfig   ESewaConfiguration @relation(fields: [esewaConfigId], references: [ispId], onDelete: Cascade, map: "esewa_access_token_config_fkey")

  @@index([esewaConfigId])
  @@index([expiresAt])
  @@index([isRevoked])
}

model ESewaRefreshToken {
  id            String   @id @default(cuid())
  token         String   @db.Text
  esewaConfigId Int
  expiresAt     DateTime
  isRevoked     Boolean  @default(false)
  createdAt     DateTime @default(now())
  esewaConfig   ESewaConfiguration @relation(fields: [esewaConfigId], references: [ispId], onDelete: Cascade, map: "esewa_refresh_token_config_fkey")

  @@index([esewaConfigId])
  @@index([expiresAt])
  @@index([isRevoked])
}

