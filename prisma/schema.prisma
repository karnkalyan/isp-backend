  lastCapabilityDetectionAt DateTime?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
  device                   ManagedDevice @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  @@index([ispId, preferredProtocol])
