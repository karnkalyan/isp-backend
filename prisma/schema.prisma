  updatedAt           DateTime  @updatedAt
  lastSync            DateTime?

  isp                 ISP       @relation(fields: [ispId], references: [id], onDelete: Cascade, map: "yeastar_trunk_isp_fkey")

  @@unique([ispId, trunkname])
  @@index([ispId])
  @@index([trunktype])
  @@index([status])
  @@index([isActive])
  @@map("yeastar_trunks")
}

model YeastarCallLog {
  id           Int      @id @default(autoincrement())
  ispId        Int
  extensionId  Int?
  callid       String?
  channelid    String?
  direction    String?  @db.VarChar(20)
  caller       String?  @db.VarChar(50)
  called       String?  @db.VarChar(50)
  trunkname    String?
  memberstatus String?
  callpath     String?
  duration     Int?
  startTime    DateTime?
  endTime      DateTime?
  status       String?  @db.VarChar(50)
  eventType    String?  @db.VarChar(100)
  eventData    Json?
  rawData      Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  isp         ISP              @relation(fields: [ispId], references: [id], onDelete: Cascade, map: "yeastar_call_log_isp_fkey")
  extension   YeastarExtension? @relation(fields: [extensionId], references: [id], map: "yeastar_call_log_extension_fkey")

  @@index([ispId])
  @@index([callid])
  @@index([channelid])
  @@index([extensionId])
  @@index([startTime])
  @@index([direction])
  @@index([status])
  @@map("yeastar_call_logs")
}

model YeastarActiveCall {
  id           Int      @id @default(autoincrement())
  ispId        Int
  callid       String   @unique
  channelid    String
  extension    String?
  caller       String?
  called       String?
  direction    String?  @db.VarChar(20)
  trunkname    String?
  status       String   @db.VarChar(50)
  startTime    DateTime @default(now())
  duration     Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  isp         ISP @relation(fields: [ispId], references: [id], onDelete: Cascade, map: "yeastar_active_call_isp_fkey")

  @@index([ispId])
  @@index([channelid])
  @@index([extension])
  @@index([isActive])
  @@map("yeastar_active_calls")
}

model YeastarSystemStatus {
  id               Int      @id @default(autoincrement())
  ispId            Int      @unique
  pbxIp            String
  apiPort          Int      @default(80)
  tcpPort          Int      @default(8333)
  version          String?
  totalExtensions  Int      @default(0)
  activeExtensions Int      @default(0)
  totalTrunks      Int      @default(0)
  activeTrunks     Int      @default(0)
  activeCalls      Int      @default(0)
