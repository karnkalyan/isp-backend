datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ==================== BRANCH MODEL ====================
model Branch {
  id            Int      @id @default(autoincrement())
  name          String
  code          String   @unique
  email         String?
  phoneNumber   String?
  address       String?
  city          String?
  state         String?
  zipCode       String?
  country       String?
  contactPerson String?
  logoUrl       String?
  isActive      Boolean  @default(true)
  isDeleted     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  invoiceEnd               Int?
  invoiceStart             Int?
  parentId                 Int?
  commissionLimitEnabled   Boolean @default(false)
  commissionType           String? @default("PERCENTAGE")
  commissionValue          Float?  @default(0)
  discountThresholdEnabled Boolean @default(false)
  discountThresholdValue   Float?  @default(0)
  invoicePrefix            String?
  infraShareDeviceRequired Boolean @default(false)
  receiptRequired          Boolean @default(false)
  smsEnabled               Boolean @default(true)
  smsUseParentProvider     Boolean @default(true)
  smsProviderCode          String?

  // Foreign Keys
  ispId Int
  isp   ISP @relation(fields: [ispId], references: [id], onDelete: Cascade, map: "branch_isp_fkey")

  // Relations
  departments              Department[]
  users                    User[]
  customers                Customer[]
  leads                    Lead[]
  subBranchLeads           Lead[]                    @relation("LeadSubBranch")
  olts                     OLT[]
  onts                     ONT[]
  splitters                Splitter[]
  memberships              Membership[]
  existingISPs             ExistingISP[]
  connectionUsers          ConnectionUser[]
  customerDocuments        CustomerDocument[]
  esewaPayments            ESewaTokenPayment[]
  terminalSessions         TerminalSession[]
  terminalCommands         TerminalCommand[]
  userBranches             UserBranch[]
  messages                 Message[]
  tickets                  Ticket[]
  tasks                    Task[]
  notices                  Notice[]
  notifications            Notification[]
  subBranchCustomers       Customer[]                @relation("CustomerSubBranch")
  bulkBranchAssignments    BulkInventoryAssignment[] @relation("BulkInvBranch")
  bulkSubBranchAssignments BulkInventoryAssignment[] @relation("BulkInvSubBranch")
  drumBranchAssignments    DrumAssignment[]          @relation("DrumBranch")
  branchRequests           BranchRequest[]
  managedDevices           ManagedDevice[]

  parent      Branch?  @relation("BranchHierarchy", fields: [parentId], references: [id])
  subBranches Branch[] @relation("BranchHierarchy")

  @@index([ispId])
  @@index([code])
  @@index([isActive])
  @@map("branches")
}

// ==================== ISP MODEL ====================
model ISP {
  id                Int      @id @default(autoincrement())
  companyName       String
  businessType      String?
  website           String?
  contactPerson     String?
  phoneNumber       String?
  masterEmail       String   @unique
  passwordHash      String?
  description       String?
  address           String?
  city              String?
  state             String?
  zipCode           String?
  country           String?
  asnNumber         String?
  ipv4Blocks        String?
  ipv6Blocks        String?
  upstreamProviders String?
  logoUrl           String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relations
  serviceLogs          ServiceLog[]
  yeastarCallLogs      YeastarCallLog[]
  yeastarExtensions    YeastarExtension[]
  yeastarTrunks        YeastarTrunk[]
  yeastarActiveCalls   YeastarActiveCall[]
  yeastarSystemStatus  YeastarSystemStatus[]
  asteriskCallLogs     AsteriskCallLog[]
  asteriskExtensions   AsteriskExtension[]
  asteriskTrunks       AsteriskTrunk[]
  asteriskActiveCalls  AsteriskActiveCall[]
  asteriskSystemStatus AsteriskSystemStatus[]
  branches             Branch[]
  departments          Department[]
  users                User[]
  connectionTypes      ConnectionType[]
  oneTimeCharges       OneTimeCharge[]
  packagePlans         PackagePlan[]
  packagePrices        PackagePrice[]
  customers            Customer[]
  esewaConfig          ESewaConfiguration?
  esewaPayments        ESewaTokenPayment[]
  CustomerDocument     CustomerDocument[]
  leads                Lead[]
  connectionUsers      ConnectionUser[]
  services             ISPService[]
  memberships          Membership[]
  existingISPs         ExistingISP[]
  olts                 OLT[]
  onts                 ONT[]
  TerminalSession      TerminalSession[]
  TerminalCommand      TerminalCommand[]
  pushTokens           UserPushToken[]
  splitters            Splitter[]
  messages             Message[]
  tickets              Ticket[]
  tasks                Task[]
  notices              Notice[]
  notifications        Notification[]
  branchRequests       BranchRequest[]
  managedDevices       ManagedDevice[]
}

// ==================== USER MODEL ====================
model User {
  id                     Int         @id @default(autoincrement())
  email                  String      @unique
  passwordHash           String
  name                   String?
  roleId                 Int?
  role                   Role?       @relation(fields: [roleId], references: [id], map: "user_role_fkey")
  status                 UserStatus  @default(pending)
  lastLogin              DateTime?
  profilePicture         String?
  departmentId           Int?
  department             Department? @relation(fields: [departmentId], references: [id], map: "user_department_fkey")
  ispId                  Int?
  isp                    ISP?        @relation(fields: [ispId], references: [id], map: "user_isp_fkey")
  branchId               Int?
  branch                 Branch?     @relation(fields: [branchId], references: [id], map: "user_branch_fkey")
  isDeleted              Boolean     @default(false)
  createdAt              DateTime    @default(now())
  updatedAt              DateTime    @updatedAt
  yeastarExt             String?
  customerId             Int?        @unique
  customer               Customer?   @relation("CustomerPortalUser", fields: [customerId], references: [id], onDelete: SetNull, map: "user_customer_fkey")
  passwordResetTokenHash String?     @unique @db.VarChar(64)
  passwordResetExpiresAt DateTime?

  // Relations
  refreshTokens       RefreshToken[]
  leads               Lead[]                    @relation("AssignedUser")
  convertedLeads      Lead[]                    @relation("ConvertedByUser")
  installations       Customer[]                @relation("InstalledBy")
  assignedFollowUps   FollowUp[]                @relation("AssignedFollowUps")
  userBranches        UserBranch[]
  sentMessages        Message[]                 @relation("SentMessages")
  receivedMessages    Message[]                 @relation("ReceivedMessages")
  assignedTickets     Ticket[]                  @relation("TicketAssignedTo")
  createdTickets      Ticket[]                  @relation("TicketCreatedBy")
  ticketComments      TicketComment[]
  createdNotices      Notice[]                  @relation("NoticeCreatedBy")
  assignedTasks       Task[]                    @relation("TaskAssignedTo")
  createdTasks        Task[]                    @relation("TaskCreatedBy")
  notifications       Notification[]
  taskActivityLogs    TaskActivityLog[]
  bulkUserAssignments BulkInventoryAssignment[] @relation("BulkInvUser")
  drumUserAssignments DrumAssignment[]          @relation("DrumUser")
  auditLogs           AuditLog[]                @relation("UserAuditLogs")
  pushTokens          UserPushToken[]

  @@unique([ispId, yeastarExt])
  @@index([branchId])
  @@index([ispId])
  @@index([roleId])
  @@index([status])
}

model MessageTemplate {
  id        Int      @id @default(autoincrement())
  ispId     Int
  channel   String   @db.VarChar(16)
  eventKey  String   @db.VarChar(80)
  name      String   @db.VarChar(160)
  subject   String?  @db.VarChar(255)
  body      String   @db.LongText
  isActive  Boolean  @default(true)
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@index([ispId, channel], map: "message_templates_isp_channel_idx")
  @@index([ispId, channel, eventKey], map: "message_templates_event_idx")
  @@map("message_templates")
}

// ==================== ROLE & PERMISSION MODELS ====================
model Role {
  id          Int          @id @default(autoincrement())
  name        String       @unique
  isActive    Boolean      @default(true)
  permissions Permission[] @relation("RolePermissions")
  users       User[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Permission {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  menuName  String
  roles     Role[]   @relation("RolePermissions")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Department {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  users       User[]
  ispId       Int?
  isp         ISP?     @relation(fields: [ispId], references: [id], map: "department_isp_fkey")
  branchId    Int?
  branch      Branch?  @relation(fields: [branchId], references: [id], map: "department_branch_fkey")
  isDeleted   Boolean  @default(false)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum UserStatus {
  active
  inactive
  pending
  disabled
}

// ==================== AUTH MODELS ====================
model RefreshToken {
  id        String   @id @default(uuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade, map: "refresh_token_user_fkey")
  userId    Int
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

// ==================== CONNECTION & PACKAGE MODELS ====================
model ConnectionType {
  id                    Int           @id @default(autoincrement())
  name                  String?
  iconUrl               String?
  code                  String?
  isExtra               Boolean       @default(false)
  description           String?
  isActive              Boolean       @default(true)
  isDeleted             Boolean       @default(false)
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  ispId                 Int?
  isp                   ISP?          @relation(fields: [ispId], references: [id], map: "connection_type_isp_fkey")
  connectionTypeDetails PackagePlan[]
}

model PackagePlan {
  id       Int     @id @default(autoincrement())
  planName String?
  planCode String? @unique

  radgroupreplyId Int? @unique // <-- ADD THIS

  connectionType        Int
  connectionTypeDetails ConnectionType? @relation(fields: [connectionType], references: [id])

  dataLimit     Int?
  downSpeed     Int?
  upSpeed       Int?
  intUpload     Int?
  firDownload   Int?
  localUpload   Int?
  localDownload Int?

  ispId Int?
  isp   ISP? @relation(fields: [ispId], references: [id])

  deviceLimit            Int?
  isPopular              Boolean @default(false)
  description            String?
  nasType                String?
  service                String?
  priority               String?
  vendorProfiles         Json?
  packageType            String?
  allowRename            Boolean @default(false)
  fupApply               Boolean @default(true)
  fupLimitGb             Int?
  fupPenaltyPlanId       Int?
  isFupPackage           Boolean @default(false)
  onlyRenewal            Boolean @default(false)
  applyFramedPool        Boolean @default(false)
  framedPoolValue        String?
  customRadiusAttributes Json?
  maxDiscountPercentage  Float?  @default(100)
  maxDiscountCount       Int?    @default(0)
  highPriority           Boolean @default(false)

  isActive  Boolean @default(true)
  isDeleted Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  packagePlanDetails PackagePrice[]
}

model PackagePrice {
  id                    Int                       @id @default(autoincrement())
  planId                Int
  packagePlanDetails    PackagePlan?              @relation(fields: [planId], references: [id], map: "package_price_plan_fkey")
  price                 Float
  initialTotalWithTax   Float?
  renewAmountWithTax    Float?
  packageDuration       String?
  referenceId           String?                   @unique
  packageName           String?
  isTrial               Boolean                   @default(false)
  isTscApplicable       Boolean?                  @default(false)
  isActive              Boolean                   @default(true)
  isOnline              Boolean                   @default(false)
  isDeleted             Boolean                   @default(false)
  addonPricesJson       String?
  createdAt             DateTime                  @default(now())
  updatedAt             DateTime                  @updatedAt
  ispId                 Int?
  isp                   ISP?                      @relation(fields: [ispId], references: [id], map: "package_price_isp_fkey")
  oneTimeCharges        OneTimeCharge[]           @relation("PackageOneTimeCharges")
  customerSubscriptions CustomerSubscription[]
  // Renamed unnamed relation and added relation name
  customer              Customer[]                @relation("PackagePriceCustomers")
  orders                CustomerOrderManagement[] @relation("PackageOrders")
  lead                  Lead[]
  customersSubscribed   Customer[]                @relation("SubscribedPackage")
}

model OneTimeCharge {
  id                 Int            @id @default(autoincrement())
  name               String?
  code               String?
  referenceId        String?
  isTaxable          Boolean        @default(true)
  isTscApplicable    Boolean        @default(false)
  iconUrl            String?
  description        String?
  amount             Float?
  forPackageCreation Boolean        @default(false)
  isRenewal          Boolean        @default(false)
  ispId              Int?
  isActive           Boolean        @default(true)
  isDeleted          Boolean        @default(false)
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  isp                ISP?           @relation(fields: [ispId], references: [id], map: "one_time_charge_isp_fkey")
  applicablePackages PackagePrice[] @relation("PackageOneTimeCharges")
}

// ==================== LEAD & FOLLOW-UP MODELS ====================
model Lead {
  id                     Int           @id @default(autoincrement())
  isActive               Boolean       @default(true)
  isDeleted              Boolean       @default(false)
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt
  convertedToCustomer    Boolean       @default(false)
  status                 LeadStatus    @default(new)
  firstName              String?
  middleName             String?
  lastName               String?
  email                  String?       @unique
  phoneNumber            String?
  secondaryContactNumber String?
  gender                 String?
  address                String?
  street                 String?
  district               String?
  province               String?
  source                 String?
  notes                  String?
  convertedAt            DateTime?
  nextFollowUp           DateTime?
  branchId               Int?
  branch                 Branch?       @relation(fields: [branchId], references: [id], map: "lead_branch_fkey")
  subBranchId            Int?
  subBranch              Branch?       @relation("LeadSubBranch", fields: [subBranchId], references: [id], onDelete: SetNull, map: "lead_subbranch_fkey")
  ispId                  Int?
  isp                    ISP?          @relation(fields: [ispId], references: [id], map: "lead_isp_fkey")
  memberShipId           Int?
  membership             Membership?   @relation(fields: [memberShipId], references: [id], map: "lead_membership_fkey")
  assignedUserId         Int?
  assignedUser           User?         @relation("AssignedUser", fields: [assignedUserId], references: [id], map: "lead_assigned_user_fkey")
  interestedPackageId    Int?
  interestedPackage      PackagePrice? @relation(fields: [interestedPackageId], references: [id], map: "lead_interested_package_fkey")
  convertedById          Int?
  convertedBy            User?         @relation("ConvertedByUser", fields: [convertedById], references: [id], map: "lead_converted_by_fkey")
  followUps              FollowUp[]
  customers              Customer[]
  tickets                Ticket[]
  metadata               Json?

  @@index([status])
  @@index([convertedToCustomer])
  @@index([assignedUserId])
  @@index([ispId])
  @@index([createdAt])
  @@index([email])
  @@index([phoneNumber])
  @@index([source])
  @@index([province])
  @@index([district])
  @@index([gender])
  @@index([branchId])
  @@map("lead")
}

enum LeadStatus {
  new
  contacted
  qualified
  unqualified
  converted
}

model FollowUp {
  id             Int            @id @default(autoincrement())
  leadId         Int
  lead           Lead           @relation(fields: [leadId], references: [id], onDelete: Cascade, map: "followup_lead_fkey")
  assignedUserId Int
  assignedUser   User           @relation("AssignedFollowUps", fields: [assignedUserId], references: [id], map: "followup_assigned_user_fkey")
  type           FollowUpType   @default(CALL)
  status         FollowUpStatus @default(SCHEDULED)
  title          String
  description    String?
  scheduledAt    DateTime
  completedAt    DateTime?
  notes          String?
  outcome        String?
  isActive       Boolean        @default(true)
  isDeleted      Boolean        @default(false)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([leadId])
  @@index([assignedUserId])
  @@index([scheduledAt])
}

enum FollowUpType {
  CALL
  EMAIL
  MEETING
  VISIT
  OTHER
}

enum FollowUpStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
  MISSED
}

model Customer {
  id               Int     @id @default(autoincrement())
  customerUniqueId String? @unique
  panNo            String? @unique
  idNumber         String

  leadId Int  @unique
  lead   Lead @relation(fields: [leadId], references: [id], map: "customer_lead_fkey")

  membershipId Int?
  membership   Membership? @relation(fields: [membershipId], references: [id], map: "customer_membership_fkey")

  branchId       Int?
  branch         Branch?       @relation(fields: [branchId], references: [id], map: "customer_branch_fkey")
  subBranchId    Int?
  subBranch      Branch?       @relation("CustomerSubBranch", fields: [subBranchId], references: [id], onDelete: SetNull, map: "customer_subbranch_fkey")
  customerTypeId Int?
  customerType   CustomerType? @relation("CustomerTypeCustomers", fields: [customerTypeId], references: [id], onDelete: SetNull, map: "customer_customertype_fkey")
  ispId          Int?
  isp            ISP?          @relation(fields: [ispId], references: [id], map: "customer_isp_fkey")
  isRechargeable Boolean?      @default(false)

  installedById Int?
  installedBy   User? @relation("InstalledBy", fields: [installedById], references: [id], map: "customer_installedby_fkey")

  oltId Int?
  olt   OLT? @relation("OLTCustomers", fields: [oltId], references: [id], map: "customer_olt_fkey")

  splitterId Int?
  splitter   Splitter? @relation("SplitterCustomers", fields: [splitterId], references: [id], map: "customer_splitter_fkey")

  existingISPId Int?
  existingISP   ExistingISP? @relation("ExistingISPCustomers", fields: [existingISPId], references: [id], map: "customer_existingisp_fkey")

  // Package fields (direct foreign keys)
  assignedPkg  Int? // trial package
  packagePrice PackagePrice? @relation("PackagePriceCustomers", fields: [assignedPkg], references: [id], map: "customer_assignedpkg_fkey")

  subscribedPkgId Int? // main (paid) package
  subscribedPkg   PackagePrice? @relation("SubscribedPackage", fields: [subscribedPkgId], references: [id], map: "customer_subscribedpkg_fkey")

  devices        CustomerDevice[]
  serviceDetails CustomerServiceConnection[]
  subscribedApps CustomerSubscribedService[]

  connectionUsers       ConnectionUser[]
  customerSubscriptions CustomerSubscription[]
  portalUser            User?                     @relation("CustomerPortalUser")
  orders                CustomerOrderManagement[]
  documents             CustomerDocument[]
  wifiCredentials       CustomerWiFiCredential[]
  referrals             CustomerReferral[]
  esewaPayments         ESewaTokenPayment[]
  tickets               Ticket[]
  tasks                 Task[]
  branchRequests        BranchRequest[]

  status        String?  @default("active")
  isDeleted     Boolean? @default(false)
  onboardStatus String?  @default("completed")
  isFree        Boolean? @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([customerUniqueId])
  @@index([status])
  @@index([branchId])
}

model CustomerDevice {
  id                  Int      @id @default(autoincrement())
  customerId          Int
  customer            Customer @relation(fields: [customerId], references: [id], onDelete: Cascade, map: "customer_device_customer_fkey")
  deviceType          String
  brand               String?
  model               String?
  serialNumber        String?  @unique
  macAddress          String?  @unique
  ponSerial           String? // <-- NEW FIELD
  ponVendorIdIncluded Boolean  @default(true)
  provisioningStatus  String   @default("pending")
  notes               String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([customerId])
  @@index([serialNumber])
}

model CustomerServiceConnection {
  id                Int       @id @default(autoincrement())
  customerId        Int
  customer          Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade, map: "customer_service_connection_customer_fkey")
  oltId             Int?
  olt               OLT?      @relation(fields: [oltId], references: [id], map: "customer_service_connection_olt_fkey")
  splitterId        Int?
  splitter          Splitter? @relation(fields: [splitterId], references: [id], map: "customer_service_connection_splitter_fkey")
  oltPort           String?
  splitterPort      String?
  vlanId            String?
  vlanPriority      String?   @default("0")
  connectionType    String?   @default("fiber")
  status            String    @default("active")
  provisioningNotes String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([customerId])
  @@index([oltId])
  @@index([splitterId])
}

model CustomerSubscribedService {
  id          Int       @id @default(autoincrement())
  customerId  Int
  customer    Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade, map: "customer_subscribed_service_customer_fkey")
  serviceId   Int
  service     Service   @relation(fields: [serviceId], references: [id], map: "customer_subscribed_service_service_fkey")
  status      String    @default("active")
  validUntil  DateTime?
  serviceData Json?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([customerId, serviceId])
}

model CustomerDocument {
  id           Int      @id @default(autoincrement())
  customerId   Int
  customer     Customer @relation(fields: [customerId], references: [id], map: "customer_document_customer_fkey")
  documentType String
  fileName     String
  filePath     String
  mimeType     String?
  size         Int?
  uploadedAt   DateTime @default(now())
  isDeleted    Boolean  @default(false)
  branchId     Int?
  branch       Branch?  @relation(fields: [branchId], references: [id], map: "customer_document_branch_fkey")
  ispId        Int?
  isp          ISP?     @relation(fields: [ispId], references: [id], map: "customer_document_isp_fkey")

  @@unique([customerId, documentType])
  @@index([customerId])
  @@index([documentType])
  @@index([branchId])
}

model ConnectionUser {
  id         Int      @id @default(autoincrement())
  customerId Int
  customer   Customer @relation(fields: [customerId], references: [id], map: "connection_user_customer_fkey")
  username   String   @unique
  password   String
  branchId   Int?
  branch     Branch?  @relation(fields: [branchId], references: [id], map: "connection_user_branch_fkey")
  ispId      Int?
  isp        ISP?     @relation(fields: [ispId], references: [id], map: "connection_user_isp_fkey")
  isActive   Boolean  @default(true)
  isDeleted  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([branchId])
}

model CustomerWiFiCredential {
  id           Int       @id @default(autoincrement())
  customerId   Int
  customer     Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  ispId        Int?
  serialNumber String
  ssidIndex    Int
  instance     String?
  ssidName     String?
  password     String?
  source       String?   @default("genieacs")
  lastSyncedAt DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([customerId, serialNumber, ssidIndex])
  @@index([serialNumber])
  @@index([ispId])
}

model CustomerReferral {
  id            Int       @id @default(autoincrement())
  customerId    Int
  customer      Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  ispId         Int?
  friendName    String
  friendPhone   String
  friendEmail   String?
  friendAddress String?
  status        String    @default("pending")
  offerNote     String?   @default("Once approved, both the referrer and friend receive the active referral offer.")
  approvedAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([customerId])
  @@index([ispId])
  @@index([status])
}

// ==================== OLT & RELATED MODELS ====================
model OLT {
  id                Int       @id @default(autoincrement())
  name              String
  ipAddress         String
  model             String
  vendor            String
  serialNumber      String?
  firmwareVersion   String?
  status            String    @default("online")
  lastSeen          DateTime?
  totalPorts        Int       @default(0)
  usedPorts         Int       @default(0)
  availablePorts    Int       @default(0)
  totalSubscribers  Int       @default(0)
  activeSubscribers Int       @default(0)
  sshHost           String?
  sshPort           Int?      @default(22)
  sshUsername       String?
  sshPassword       String?
  sshEnablePassword String?
  sshKey            String?
  sshTimeout        Int?      @default(30000)
  sshKeepalive      Int?      @default(5000)
  maxReconnect      Int?      @default(3)
  commandDelay      Int?      @default(1200)
  enableConfig      Boolean   @default(true)
  shellRows         Int?      @default(40)
  shellCols         Int?      @default(120)
  telnetEnabled     Boolean   @default(false)
  telnetPort        Int?      @default(23)
  snmpEnabled       Boolean   @default(true)
  snmpCommunity     String?   @default("public")
  snmpVersion       String?   @default("v2c")
  webInterface      Boolean   @default(true)
