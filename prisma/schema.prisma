model ManagedDevice {
  id                         Int      @id @default(autoincrement())
  uuid                       String   @unique @default(uuid()) @db.VarChar(36)
  ispId                      Int
  branchId                   Int?
  name                       String   @db.VarChar(160)
  slug                       String   @db.VarChar(191)
  deviceType                 String   @db.VarChar(64)
  vendor                     String   @db.VarChar(100)
  model                      String?  @db.VarChar(160)
  firmwareVersion            String?  @db.VarChar(160)
  platform                   String?  @db.VarChar(160)
  operatingSystem            String?  @db.VarChar(160)
  operatingSystemVersion     String?  @db.VarChar(160)
  serialNumber               String?  @db.VarChar(191)
  host                       String   @db.VarChar(255)
  endpointKey                String   @db.VarChar(64)
  managementPort             Int
  communicationMethod        String   @db.VarChar(24)
  defaultCommunicationMethod String   @db.VarChar(24)
  apiBaseUrl                 String?  @db.VarChar(500)
  apiPort                    Int?
  tlsEnabled                 Boolean  @default(false)
  verifyTls                  Boolean  @default(true)
  site                       String?  @db.VarChar(160)
  location                   String?  @db.VarChar(255)
  description                String?  @db.Text
  tags                       Json?
  status                     String   @default("offline") @db.VarChar(24)
  statusMessage              String?  @db.VarChar(1000)
  failureReason              String?  @db.VarChar(1000)
  maintenanceReason          String?  @db.VarChar(1000)
  maintenanceStartedAt       DateTime?
  lastCheckedAt              DateTime?
  lastSeenAt                 DateTime?
  lastSuccessfulConnectionAt DateTime?
  lastFailureAt              DateTime?
  consecutiveFailureCount    Int      @default(0)
  pollingEnabled             Boolean  @default(true)
  pollingInterval            Int      @default(300)
  connectionTimeout          Int      @default(15000)
  commandTimeout             Int      @default(15000)
  retryCount                 Int      @default(1)
  sshProfile                 String   @default("AUTO") @db.VarChar(64)
  legacyCompatibilityEnabled Boolean  @default(false)
  lastConnectionError        String?  @db.VarChar(1000)
  lastConnectionDiagnostics  Json?
  lastConfigurationBackupId  Int?
  enabled                    Boolean  @default(true)
  isDeleted                  Boolean  @default(false)
  createdBy                  Int?
  updatedBy                  Int?
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt

  credential      ManagedDeviceCredential?
  isp             ISP      @relation(fields: [ispId], references: [id], onDelete: Cascade, map: "managed_devices_ispId_fkey")
  branch          Branch?  @relation(fields: [branchId], references: [id], onDelete: SetNull, map: "managed_devices_branchId_fkey")
  connections     ManagedDeviceConnection[]
  statusHistory   ManagedDeviceStatusHistory[]
  snapshots       ManagedDeviceSnapshot[]
  backups         ManagedDeviceBackup[]
  audits          ManagedDeviceAudit[]
  commands        ManagedDeviceCommand[]
  capabilities    ManagedDeviceCapability[]
  configurationTasks ManagedDeviceConfigurationTask[]
  connectionProfile ManagedDeviceConnectionProfile?

  @@unique([ispId, slug])
  @@unique([ispId, deviceType, endpointKey])
  @@index([ispId, deviceType, isDeleted])
  @@index([ispId, status, enabled, pollingEnabled])
  @@index([branchId])
  @@map("managed_devices")
}

