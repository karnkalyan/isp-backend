  branch          Branch?    @relation(fields: [branchId], references: [id], map: "existing_isp_branch_fkey")
  ispId           Int?
  isp             ISP?       @relation(fields: [ispId], references: [id], onDelete: Cascade, map: "existing_isp_isp_fkey")
  isActive        Boolean    @default(true)
  isDeleted       Boolean    @default(false)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  // Renamed direct customer relation
  customers       Customer[] @relation("ExistingISPCustomers")

  @@index([ispId])
  @@index([branchId])
  @@map("existing_isp")
}

// ==================== SUBSCRIPTION & ORDER MODELS ====================
model CustomerSubscription {
  id           Int                       @id @default(autoincrement())
  customerId   Int
  customer     Customer                  @relation(fields: [customerId], references: [id], map: "customer_subscription_customer_fkey")
  package      Int
  packagePrice PackagePrice              @relation(fields: [package], references: [id], map: "customer_subscription_package_fkey")
  isTrial      Boolean                   @default(false)
  planStart    DateTime
  planEnd      DateTime
  isActive     Boolean                   @default(true)
  isInvoicing  Boolean                   @default(true)
  orders       CustomerOrderManagement[]
  createdAt    DateTime                  @default(now())
  updatedAt    DateTime                  @updatedAt
}

model CustomerOrderManagement {
  id             Int                  @id @default(autoincrement())
  customerId     Int
  customer       Customer             @relation(fields: [customerId], references: [id], map: "customer_order_customer_fkey")
  subscriptionId Int
  subscription   CustomerSubscription @relation(fields: [subscriptionId], references: [id], map: "customer_order_subscription_fkey")
  package        Int?
  packagePrice   PackagePrice?        @relation("PackageOrders", fields: [package], references: [id], map: "customer_order_package_fkey")
  orderDate      DateTime             @default(now())
  packageStart   DateTime
  packageEnd     DateTime
  totalAmount    Float
  items          OrderDetail[]
  isPaid         Boolean              @default(false)
  isActive       Boolean              @default(true)
  isDeleted      Boolean              @default(false)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
}

model OrderDetail {
  id          Int                     @id @default(autoincrement())
  orderId     Int
  order       CustomerOrderManagement @relation(fields: [orderId], references: [id], map: "order_detail_order_fkey")
  itemName    String
  referenceId String?
  itemPrice   Float
  createdAt   DateTime                @default(now())
}

// ==================== SERVICE MODELS ====================
model Service {
  id          Int      @id @default(autoincrement())
  name        String   @db.VarChar(100) @unique
  code        String   @db.VarChar(50)  @unique
  description String?
  iconUrl     String?
  category    ServiceCategory
  isActive    Boolean  @default(true)
  isDeleted   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  ispServices ISPService[]
  // New opposite for CustomerSubscribedService
  customerSubscribedServices CustomerSubscribedService[]

  @@index([category])
  @@index([isActive])
}

enum ServiceCategory {
  BILLING
  AUTHENTICATION
  PAYMENT
  STREAMING
  NETWORK
  VOIP
  SECURITY
  COMMUNICATION
  OTHER
  ACS
}

model ISPService {
  id          Int      @id @default(autoincrement())
  ispId       Int
  serviceId   Int
  isActive    Boolean  @default(false)
  isEnabled   Boolean  @default(true)
  isDeleted   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  baseUrl     String?
  apiVersion  String   @db.VarChar(10) @default("v1")
  config      Json?

  isp         ISP      @relation(fields: [ispId], references: [id], onDelete: Cascade, map: "isp_service_isp_fkey")
  service     Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade, map: "isp_service_service_fkey")
  credentials ServiceCredential[]

  @@unique([ispId, serviceId])
  @@index([isActive])
  @@index([isEnabled])
}

model ServiceCredential {
  id             Int      @id @default(autoincrement())
  credentialType String   @db.VarChar(30)
  key            String   @db.VarChar(50)
  value          String   @db.VarChar(255)
  label          String?  @db.VarChar(100)
  isEncrypted    Boolean  @default(true)
  description    String?
  isActive       Boolean  @default(true)
  isDeleted      Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  ispServiceId Int
  ispService   ISPService @relation(fields: [ispServiceId], references: [id], onDelete: Cascade, map: "service_credential_isp_service_fkey")

  @@unique([ispServiceId, key])
  @@index([credentialType])
}

model ServiceLog {
  id          Int      @id @default(autoincrement())
  ispId       Int
  serviceCode String
  operation   String
  status      String
  message     String?
  data        Json?
  duration    Int?
  createdAt   DateTime @default(now())
  isp         ISP      @relation(fields: [ispId], references: [id], map: "service_log_isp_fkey")
  @@index([ispId])
  @@index([serviceCode])
  @@index([createdAt])
  @@index([status])
}

// ==================== YEASTAR MODELS ====================
model YeastarExtension {
  id               Int      @id @default(autoincrement())
  ispId            Int
  pbxExtensionId   String
  extensionNumber  String
  extensionName    String?
  extensionType    String   @default("SIP")
  status           String   @default("Idle")
  agentid          String?
  isActive         Boolean  @default(true)
  isDeleted        Boolean  @default(false)
  lastSync         DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  isp              ISP      @relation(fields: [ispId], references: [id], onDelete: Cascade, map: "yeastar_extension_isp_fkey")
  callLogs         YeastarCallLog[]

  @@unique([ispId, extensionNumber])
  @@unique([ispId, pbxExtensionId])
  @@map("yeastar_extensions")
}

model YeastarTrunk {
  id                  Int       @id @default(autoincrement())
  ispId               Int
  trunkId             String    @unique
  trunkname           String
  trunktype           String    @default("register")
  pbxTrunkId          String
  host                String?
